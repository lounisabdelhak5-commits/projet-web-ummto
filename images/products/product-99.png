  <div class="ui very padded container">
    <div class="ui very tall centered grid">
      <div class="left aligned middle aligned nine wide computer twelve wide tablet sixteen wide mobile column">
        <div class="ui fluid card">
          <div class="content">
            
              
  <div class="ui center aligned header">
    
      
        Log in to view this documentation
      
    
  </div>


              
                <div class="description">
                  
  

  <div data-bind="using: LoginView({last_tab: 'vcs', last_method: 'None'})">
    <div class="ui basic horizontally fitted segment">
      <div class="ui small stackable teal centered fluid wrapping menu"
           data-bind="semanticui: {tabs: { autoTabActivation: last_tab() }}">

        <a class="item" data-tab="vcs">
          <i class="fas fa-cloud icon"></i>
          
            Connected account
          
        </a>

        
        <a class=" item"
           data-bind="semanticui: { popup: popup_login_method('email') }"
           data-tab="email">
          <i class="fas fa-envelope icon"></i>
          
            Email
          
        </a>

        
          <a class="item" data-tab="sso">
            <i class="fas fa-shield-alt icon"></i>
            Single sign-on
          </a>
        

        
          <a class="item" href="https://espressif-docs.readthedocs-hosted.com/_/projects/esp-faq/sharing/password/?next=https%3A%2F%2Fespressif-docs.readthedocs-hosted.com%2Fprojects%2Fesp-faq%2Fen%2Flatest%2F_images%2Fesp32-nodemcu.png">
            <i class="fas fa-lock icon"></i>
            
              Password
            
          </a>
        
      </div>
    </div>

    <div class="ui basic center aligned tab segment" data-tab="vcs">
      <div class="ui relaxed list">
        
          
          
          









  
  <li class="item">
    <a class="ui button"
       data-bind="click: show_github_modal, semanticui: { popup: popup_login_method(['github','githubapp'], 'right center') }"
       title="GitHub">
      <i class="fa-brands fa-github icon"></i>
      Log in using GitHub
    </a>
  </li>

  <div class="ui tiny modal"
       data-bind="semanticui: { modal: github_modal_config() }">
    <div class="header">
      Log in using GitHub
    </div>
    <div class="content">
      <p>
        Read the Docs now supports two methods for connecting your GitHub account:
      </p>
      <div class="ui segment">
        <div class="ui small divided items">
          
            <div class="item">
              <div class="content">
                <div class="header">
                  
                    Our GitHub OAuth app
                  
                </div>
                <div class="description">
                  <p>
                    
                      
                        For users that haven't switched their connected GitHub accounts to our new GitHub App.
                      
                    
                  </p>
                </div>
                <div class="extra">
                  
                    



  <form class="ui form"
        method="post"
        action="/accounts/github/login/?process=login&amp;next=%2Fcas%2Flogin%3Fsubproject%3Desp-faq%26service%3Dhttps%253A%252F%252Fespressif-docs.readthedocs-hosted.com%252F_%252Faccounts%252Flogin%252F%253Fnext%253Dhttps%25253A%25252F%25252Fespressif-docs.readthedocs-hosted.com%25252Fprojects%25252Fesp-faq%25252Fen%25252Flatest%25252F_images%25252Fesp32-nodemcu.png">
    <input type="hidden" name="csrfmiddlewaretoken" value="3VQXuxvs3MZE9Y6Ij5KTSkMuTTcw0sTaZCvSEZT5SoETDc8iPeUa5SIZ1xronaLG">

    
    <button class="ui right floated primary button"
            data-bind="click: save_login_method.bind($data, 'github'), semanticui: { popup: popup_login_method('github', 'right center') }"
            type="submit">
      

      <i class="fa-brands fa-github icon"></i>
      Log in using GitHub OAuth
    </button>

  </form>


                  
                </div>
              </div>
            </div>
          
            <div class="item">
              <div class="content">
                <div class="header">
                  
                    Our GitHub App
                  
                </div>
                <div class="description">
                  <p>
                    
                      
                        For users that have switched their connected GitHub accounts already, or that would like to switch to our new GitHub App.
                      
                    
                  </p>
                </div>
                <div class="extra">
                  
                    



  <form class="ui form"
        method="post"
        action="/accounts/githubapp/login/?process=login&amp;next=%2Fcas%2Flogin%3Fsubproject%3Desp-faq%26service%3Dhttps%253A%252F%252Fespressif-docs.readthedocs-hosted.com%252F_%252Faccounts%252Flogin%252F%253Fnext%253Dhttps%25253A%25252F%25252Fespressif-docs.readthedocs-hosted.com%25252Fprojects%25252Fesp-faq%25252Fen%25252Flatest%25252F_images%25252Fesp32-nodemcu.png">
    <input type="hidden" name="csrfmiddlewaretoken" value="3VQXuxvs3MZE9Y6Ij5KTSkMuTTcw0sTaZCvSEZT5SoETDc8iPeUa5SIZ1xronaLG">

    
    <button class="ui right floated basic button"
            data-bind="click: save_login_method.bind($data, 'githubapp'), semanticui: { popup: popup_login_method('githubapp', 'right center') }"
            type="submit">
      

      <i class="fa-brands fa-github icon"></i>
      Log in using GitHub App
    </button>

  </form>


                  
                </div>
              </div>
            </div>
          
        </div>
      </div>

      <div class="ui info message">
        <i class="fas fa-info-circle icon"></i>
        To learn more about our new GitHub App integration,
        <a href="https://about.readthedocs.com/blog/2025/06/announcing-our-github-app-beta/">read our beta announcement</a>
      </div>
    </div>
    <div class="actions">
      <div class="ui cancel button">Cancel</div>
    </div>
  </div>




  
    
  

  
    
  

  
