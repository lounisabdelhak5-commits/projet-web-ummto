  </form>


    </li>
  


        
      </div>
    </div>
    <div class="ui basic vertically fitted tab segment" data-tab="email">
      
        <p class="ui center aligned vertically fitted small basic fluid segment">
          
          Need an account? <a href="/accounts/signup/?next=%2Fcas%2Flogin%3Fsubproject%3Desp-faq%26service%3Dhttps%253A%252F%252Fespressif-docs.readthedocs-hosted.com%252F_%252Faccounts%252Flogin%252F%253Fnext%253Dhttps%25253A%25252F%25252Fespressif-docs.readthedocs-hosted.com%25252Fprojects%25252Fesp-faq%25252Fen%25252Flatest%25252F_images%25252Fesp32-nodemcu.png#/email">Sign up</a> first.
        </p>

        <form class="ui form"
              method="post"
              action="/accounts/login/#/email">
          <input type="hidden" name="csrfmiddlewaretoken" value="3VQXuxvs3MZE9Y6Ij5KTSkMuTTcw0sTaZCvSEZT5SoETDc8iPeUa5SIZ1xronaLG">
          <div class="ui basic fieldset segment">
  
    



  

  
    


  
  
    





  

  <div id="div_id_login" class="required field">

  
    
      
      <label for="id_login"
             class="ui "
             >
        Login
        
      </label>
    
  

  
    
      <div class="">
        <input type="text" name="login" placeholder="Username or email" autocomplete="email" class="textinput textInput" required id="id_login">
        

      </div>
    
  

  </div>


  


  
    


  
  
    





  

  <div id="div_id_password" class="required field">

  
    
      
      <label for="id_password"
             class="ui "
              data-html="&lt;a href=&quot;/accounts/password/reset/&quot;&gt;Forgot your password?&lt;/a&gt;" data-bind="semanticui: {popup: {hoverable: true, delay: {show: 500}}}">
        Password
        
          <i class="ui grey fa-duotone fa-circle-question icon"></i>
        
      </label>
    
  

  
    
      <div class="">
        <input type="password" name="password" placeholder="Password" autocomplete="current-password" class="textinput textInput" required aria-describedby="id_password_helptext" id="id_password">
        

      </div>
    
  

  </div>


  


  
    


  
  
    




  <div class="field">
    <div class="ui checkbox">
      
        

  

  <div id="div_id_remember" class="">

  


  
  <input type="checkbox" name="remember" class="checkboxinput form-check-input" id="id_remember">

  
    <label for="id_remember" class="form-check-label">
      Remember Me

      
    </label>
  

  



  </div>

      
    </div>
  </div>


  


  
</div>


          
            <input type="hidden"
                   name="next"
